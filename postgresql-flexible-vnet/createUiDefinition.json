{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [
      {
        "name": "serverName",
        "type": "Microsoft.Common.TextBox",
        "label": "Server Name",
        "placeholder": "e.g., my-postgresql-server",
        "toolTip": "The name of the PostgreSQL Flexible Server (must be globally unique, 3-63 characters, lowercase letters, numbers, and hyphens only)",
        "constraints": {
          "required": true,
          "validations": [
            {
              "regex": "^[a-z0-9][a-z0-9-]{1,61}[a-z0-9]$",
              "message": "Server name must be 3-63 characters, lowercase letters, numbers, and hyphens only, and cannot start or end with a hyphen."
            }
          ]
        }
      },
      {
        "name": "administratorLogin",
        "type": "Microsoft.Common.TextBox",
        "label": "Administrator Login",
        "placeholder": "e.g., pgadmin",
        "toolTip": "Database administrator username (1-63 characters, letters and numbers only)",
        "constraints": {
          "required": true,
          "validations": [
            {
              "regex": "^[a-zA-Z0-9]{1,63}$",
              "message": "Administrator login must be 1-63 characters, letters and numbers only."
            }
          ]
        }
      },
      {
        "name": "administratorLoginPassword",
        "type": "Microsoft.Common.PasswordBox",
        "label": {
          "password": "Administrator Password",
          "confirmPassword": "Confirm Password"
        },
        "toolTip": "Database administrator password (minimum 8 characters, must include uppercase, lowercase, number, and special character)",
        "constraints": {
          "required": true,
          "validations": [
            {
              "regex": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[a-zA-Z\\d@$!%*?&]{8,128}$",
              "message": "Password must be 8-128 characters and include at least one uppercase letter, one lowercase letter, one number, and one special character (@$!%*?&)."
            }
          ]
        },
        "options": {
          "hideConfirmation": false
        },
        "visible": true
      }
    ],
    "steps": [
      {
        "name": "databaseSettings",
        "label": "Database Settings",
        "elements": [
          {
            "name": "postgresqlVersion",
            "type": "Microsoft.Common.DropDown",
            "label": "PostgreSQL Version",
            "defaultValue": "14",
            "toolTip": "Select the PostgreSQL version",
            "constraints": {
              "allowedValues": [
                {
                  "label": "PostgreSQL 11",
                  "value": "11"
                },
                {
                  "label": "PostgreSQL 12",
                  "value": "12"
                },
                {
                  "label": "PostgreSQL 13",
                  "value": "13"
                },
                {
                  "label": "PostgreSQL 14",
                  "value": "14"
                },
                {
                  "label": "PostgreSQL 15",
                  "value": "15"
                },
                {
                  "label": "PostgreSQL 16",
                  "value": "16"
                },
                {
                  "label": "PostgreSQL 17",
                  "value": "17"
                },
                {
                  "label": "PostgreSQL 18",
                  "value": "18"
                }
              ],
              "required": true
            }
          },
          {
            "name": "databaseName",
            "type": "Microsoft.Common.TextBox",
            "label": "Database Name",
            "placeholder": "e.g., myappdb",
            "toolTip": "The name of the PostgreSQL database to create",
            "constraints": {
              "required": false,
              "validations": [
                {
                  "regex": "^[a-zA-Z_][a-zA-Z0-9_]{0,62}$",
                  "message": "Database name must start with a letter or underscore, contain only letters, numbers, and underscores, and be 1-63 characters."
                }
              ]
            }
          },
          {
            "name": "skuInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "Select the appropriate SKU based on your workload requirements. Burstable is suitable for development/testing, General Purpose for typical applications, and Memory Optimized for high-performance workloads."
            }
          },
          {
            "name": "skuTier",
            "type": "Microsoft.Common.DropDown",
            "label": "Pricing Tier",
            "defaultValue": "GeneralPurpose",
            "toolTip": "Select the pricing tier",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Burstable (Development/Test)",
                  "value": "Burstable"
                },
                {
                  "label": "General Purpose (Standard)",
                  "value": "GeneralPurpose"
                },
                {
                  "label": "Memory Optimized (High Performance)",
                  "value": "MemoryOptimized"
                }
              ],
              "required": true
            }
          },
          {
            "name": "skuName",
            "type": "Microsoft.Common.DropDown",
            "label": "Compute + Storage SKU",
            "defaultValue": "Standard_D2ds_v4",
            "toolTip": "Select the compute and storage tier. Larger SKUs provide more CPU, memory, and IOPS.",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Standard_B1ms (Burstable, 1 vCore, 0.5 GB RAM)",
                  "value": "Standard_B1ms"
                },
                {
                  "label": "Standard_B2s (Burstable, 2 vCores, 4 GB RAM)",
                  "value": "Standard_B2s"
                },
                {
                  "label": "Standard_D2ds_v4 (General Purpose, 2 vCores, 8 GB RAM)",
                  "value": "Standard_D2ds_v4"
                },
                {
                  "label": "Standard_D4ds_v4 (General Purpose, 4 vCores, 16 GB RAM)",
                  "value": "Standard_D4ds_v4"
                },
                {
                  "label": "Standard_D8ds_v4 (General Purpose, 8 vCores, 32 GB RAM)",
                  "value": "Standard_D8ds_v4"
                },
                {
                  "label": "Standard_D16ds_v4 (General Purpose, 16 vCores, 64 GB RAM)",
                  "value": "Standard_D16ds_v4"
                },
                {
                  "label": "Standard_E2ds_v4 (Memory Optimized, 2 vCores, 16 GB RAM)",
                  "value": "Standard_E2ds_v4"
                },
                {
                  "label": "Standard_E4ds_v4 (Memory Optimized, 4 vCores, 32 GB RAM)",
                  "value": "Standard_E4ds_v4"
                },
                {
                  "label": "Standard_E8ds_v4 (Memory Optimized, 8 vCores, 64 GB RAM)",
                  "value": "Standard_E8ds_v4"
                }
              ],
              "required": true
            }
          },
          {
            "name": "storageSizeGB",
            "type": "Microsoft.Common.Slider",
            "min": 32,
            "max": 16384,
            "step": 32,
            "label": "Storage Size (GB)",
            "defaultValue": 32,
            "toolTip": "Database storage size between 32 GB and 16 TB",
            "constraints": {
              "required": true
            }
          }
        ]
      },
      {
        "name": "backupAndHA",
        "label": "Backup & High Availability",
        "elements": [
          {
            "name": "backupRetentionDays",
            "type": "Microsoft.Common.Slider",
            "min": 7,
            "max": 35,
            "step": 1,
            "label": "Backup Retention (Days)",
            "defaultValue": 7,
            "toolTip": "Number of days to retain automated backups (7-35 days)",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "geoRedundantBackup",
            "type": "Microsoft.Common.DropDown",
            "label": "Geo-Redundant Backup",
            "defaultValue": "Disabled",
            "toolTip": "Enable backups to be replicated to a geographically distant region for disaster recovery",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Disabled",
                  "value": "Disabled"
                },
                {
                  "label": "Enabled",
                  "value": "Enabled"
                }
              ],
              "required": true
            }
          },
          {
            "name": "highAvailability",
            "type": "Microsoft.Common.DropDown",
            "label": "High Availability (Zone Redundant)",
            "defaultValue": "Disabled",
            "toolTip": "Enable zone-redundant high availability to automatically failover to a standby replica in a different availability zone",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Disabled",
                  "value": "Disabled"
                },
                {
                  "label": "Zone Redundant",
                  "value": "ZoneRedundant"
                },
                {
                  "label": "Same Zone",
                  "value": "SameZone"
                }
              ],
              "required": true
            }
          }
        ]
      },
      {
        "name": "networkSettings",
        "label": "Network Settings",
        "elements": [
          {
            "name": "virtualNetworkName",
            "type": "Microsoft.Common.TextBox",
            "label": "Virtual Network Name",
            "placeholder": "e.g., postgresql-vnet",
            "defaultValue": "postgresql-vnet",
            "toolTip": "Name of the virtual network to create",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[a-zA-Z0-9][a-zA-Z0-9-]{0,78}[a-zA-Z0-9]$",
                  "message": "Virtual network name must be 2-80 characters, start and end with alphanumeric, and contain only letters, numbers, and hyphens."
                }
              ]
            }
          },
          {
            "name": "vnetAddressPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Virtual Network Address Space (CIDR)",
            "placeholder": "e.g., 10.0.0.0/16",
            "defaultValue": "10.0.0.0/16",
            "toolTip": "Address space for the virtual network in CIDR notation",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}/[0-9]{1,2}$",
                  "message": "Virtual Network address space must be in CIDR format (e.g., 10.0.0.0/16)."
                }
              ]
            }
          },
          {
            "name": "subnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Subnet Name",
            "placeholder": "e.g., postgresql-subnet",
            "defaultValue": "postgresql-subnet",
            "toolTip": "Name of the subnet for PostgreSQL",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[a-zA-Z0-9][a-zA-Z0-9-]{0,78}[a-zA-Z0-9]$",
                  "message": "Subnet name must be 2-80 characters, start and end with alphanumeric, and contain only letters, numbers, and hyphens."
                }
              ]
            }
          },
          {
            "name": "subnetAddressPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Subnet Address Prefix (CIDR)",
            "placeholder": "e.g., 10.0.0.0/24",
            "defaultValue": "10.0.0.0/24",
            "toolTip": "Address prefix for the subnet in CIDR notation (must be within the Virtual Network address space)",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}/[0-9]{1,2}$",
                  "message": "Subnet address prefix must be in CIDR format (e.g., 10.0.0.0/24)."
                }
              ]
            }
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "serverName": "[basics('serverName')]",
      "administratorLogin": "[basics('administratorLogin')]",
      "administratorLoginPassword": "[basics('administratorLoginPassword')]",
      "databaseName": "[steps('databaseSettings').databaseName]",
      "postgresqlVersion": "[steps('databaseSettings').postgresqlVersion]",
      "skuTier": "[steps('databaseSettings').skuTier]",
      "skuName": "[steps('databaseSettings').skuName]",
      "storageSizeGB": "[steps('databaseSettings').storageSizeGB]",
      "backupRetentionDays": "[steps('backupAndHA').backupRetentionDays]",
      "geoRedundantBackup": "[steps('backupAndHA').geoRedundantBackup]",
      "highAvailability": "[steps('backupAndHA').highAvailability]",
      "virtualNetworkName": "[steps('networkSettings').virtualNetworkName]",
      "vnetAddressPrefix": "[steps('networkSettings').vnetAddressPrefix]",
      "subnetName": "[steps('networkSettings').subnetName]",
      "subnetAddressPrefix": "[steps('networkSettings').subnetAddressPrefix]",
      "dnsZoneName": "[basics('serverName')]"
    }
  }
}
