{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys Azure Database for PostgreSQL Flexible Server with Virtual Network integration.",
    "author": "Microsoft",
    "publisher": "Microsoft",
    "version": "1.0.0"
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "serverName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63,
      "metadata": {
        "description": "The name of the PostgreSQL Flexible Server (must be globally unique)"
      }
    },
    "administratorLogin": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "metadata": {
        "description": "Database administrator login name"
      }
    },
    "administratorLoginPassword": {
      "type": "securestring",
      "minLength": 8,
      "maxLength": 128,
      "metadata": {
        "description": "Database administrator password (minimum 8 characters, must include uppercase, lowercase, number, and special character)"
      }
    },
    "databaseName": {
      "type": "string",
      "defaultValue": "postgres",
      "metadata": {
        "description": "The name of the PostgreSQL database"
      }
    },
    "postgresqlVersion": {
      "type": "string",
      "defaultValue": "14",
      "allowedValues": [
        "11",
        "12",
        "13",
        "14",
        "15",
        "16",
        "17",
        "18"
      ],
      "metadata": {
        "description": "PostgreSQL version"
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Standard_D2ds_v4",
      "allowedValues": [
        "Standard_B1ms",
        "Standard_B2s",
        "Standard_D2ds_v4",
        "Standard_D4ds_v4",
        "Standard_D8ds_v4",
        "Standard_D16ds_v4",
        "Standard_E2ds_v4",
        "Standard_E4ds_v4",
        "Standard_E8ds_v4"
      ],
      "metadata": {
        "description": "SKU (compute + storage tier) for PostgreSQL Flexible Server"
      }
    },
    "skuTier": {
      "type": "string",
      "defaultValue": "GeneralPurpose",
      "allowedValues": [
        "Burstable",
        "GeneralPurpose",
        "MemoryOptimized"
      ],
      "metadata": {
        "description": "Pricing tier for the PostgreSQL Flexible Server"
      }
    },
    "storageSizeGB": {
      "type": "int",
      "defaultValue": 32,
      "minValue": 32,
      "maxValue": 16384,
      "metadata": {
        "description": "Storage size in GB (32 GB minimum)"
      }
    },
    "backupRetentionDays": {
      "type": "int",
      "defaultValue": 7,
      "minValue": 7,
      "maxValue": 35,
      "metadata": {
        "description": "Backup retention period in days"
      }
    },
    "geoRedundantBackup": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "Enable geo-redundant backups"
      }
    },
    "highAvailability": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Disabled",
        "ZoneRedundant",
        "SameZone"
      ],
      "metadata": {
        "description": "Enable zone-redundant high availability (Disabled, ZoneRedundant, SameZone)"
      }
    },
    "virtualNetworkName": {
      "type": "string",
      "defaultValue": "postgresql-vnet",
      "metadata": {
        "description": "Name of the Virtual Network"
      }
    },
    "subnetName": {
      "type": "string",
      "defaultValue": "postgresql-subnet",
      "metadata": {
        "description": "Name of the subnet for PostgreSQL"
      }
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/16",
      "metadata": {
        "description": "Virtual Network address space (CIDR)"
      }
    },
    "subnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/24",
      "metadata": {
        "description": "Subnet address prefix (CIDR)"
      }
    },
    "dnsZoneName": {
      "type": "string",
      "defaultValue": "[parameters('serverName')]",
      "metadata": {
        "description": "Name for private DNS zone"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags to apply to all resources"
      }
    }
  },
  "variables": {
    "dnsZoneFqdn": "[format('{0}.postgres.database.azure.com', parameters('dnsZoneName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2025-05-01",
      "name": "[parameters('virtualNetworkName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetAddressPrefix')]"
          ]
        }
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2025-05-01",
      "name": "[format('{0}/{1}', parameters('virtualNetworkName'), parameters('subnetName'))]",
      "properties": {
        "addressPrefix": "[parameters('subnetAddressPrefix')]",
        "delegations": [
          {
            "name": "dlg-Microsoft.DBforPostgreSQL-flexibleServers",
            "properties": {
              "serviceName": "Microsoft.DBforPostgreSQL/flexibleServers"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2024-06-01",
      "name": "[variables('dnsZoneFqdn')]",
      "location": "global",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2024-06-01",
      "name": "[format('{0}/{1}', variables('dnsZoneFqdn'), parameters('virtualNetworkName'))]",
      "location": "global",
      "properties": {
        "registrationEnabled": false,
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', variables('dnsZoneFqdn'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2024-08-01",
      "name": "[parameters('serverName')]",
      "location": "[parameters('location')]",
      "tags": "[union(parameters('tags'), createObject('Service', 'PostgreSQL', 'Environment', 'Managed'))]",
      "sku": {
        "name": "[parameters('skuName')]",
        "tier": "[parameters('skuTier')]"
      },
      "properties": {
        "administratorLogin": "[parameters('administratorLogin')]",
        "administratorLoginPassword": "[parameters('administratorLoginPassword')]",
        "storage": {
          "storageSizeGB": "[parameters('storageSizeGB')]"
        },
        "createMode": "Default",
        "version": "[parameters('postgresqlVersion')]",
        "backup": {
          "backupRetentionDays": "[parameters('backupRetentionDays')]",
          "geoRedundantBackup": "[parameters('geoRedundantBackup')]"
        },
        "highAvailability": {
          "mode": "[parameters('highAvailability')]"
        },
        "network": {
          "delegatedSubnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), parameters('subnetName'))]",
          "privateDnsZoneArmResourceId": "[resourceId('Microsoft.Network/privateDnsZones', variables('dnsZoneFqdn'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), parameters('subnetName'))]",
        "[resourceId('Microsoft.Network/privateDnsZones/virtualNetworkLinks', variables('dnsZoneFqdn'), parameters('virtualNetworkName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2024-08-01",
      "name": "[format('{0}/{1}', parameters('serverName'), parameters('databaseName'))]",
      "properties": {},
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]"
      ]
    }
  ],
  "outputs": {
    "postgresqlServerName": {
      "type": "string",
      "value": "[parameters('serverName')]",
      "metadata": {
        "description": "The name of the PostgreSQL Flexible Server"
      }
    },
    "postgresqlHostname": {
      "type": "string",
      "value": "[variables('dnsZoneFqdn')]",
      "metadata": {
        "description": "The fully qualified domain name of the PostgreSQL server"
      }
    },
    "postgresqlVersion": {
      "type": "string",
      "value": "[parameters('postgresqlVersion')]",
      "metadata": {
        "description": "PostgreSQL version deployed"
      }
    },
    "vnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]",
      "metadata": {
        "description": "The resource ID of the virtual network"
      }
    },
    "subnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), parameters('subnetName'))]",
      "metadata": {
        "description": "The resource ID of the subnet"
      }
    },
    "privateDnsZoneId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/privateDnsZones', variables('dnsZoneFqdn'))]",
      "metadata": {
        "description": "The resource ID of the private DNS zone"
      }
    }
  }
}
