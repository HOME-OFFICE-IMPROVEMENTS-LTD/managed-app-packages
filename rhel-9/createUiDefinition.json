{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "resourceTypes": [
      "Microsoft.Compute/virtualMachines"
    ],
    "basics": [
      {
        "name": "introInfo",
        "type": "Microsoft.Common.InfoBox",
        "visible": true,
        "options": {
          "icon": "Info",
          "text": "This offer deploys a Red Hat Enterprise Linux 9 Gen2 virtual machine with Trusted Launch (Secure Boot + vTPM), a Standard static public IP, SSH key or password authentication, and full tagging support. RHEL 9 is a Red Hat published image — no separate Red Hat subscription is required for Azure PAYG deployments."
        }
      },
      {
        "name": "vmName",
        "type": "Microsoft.Common.TextBox",
        "label": "Virtual Machine Name",
        "toolTip": "Name for the virtual machine. Must be 3–15 alphanumeric characters or hyphens.",
        "placeholder": "rhel-vm",
        "constraints": {
          "required": true,
          "regex": "^[a-zA-Z0-9-]{3,15}$",
          "validationMessage": "Must be 3–15 characters: letters, numbers, and hyphens only."
        },
        "visible": true
      },
      {
        "name": "adminUsername",
        "type": "Microsoft.Compute.UserNameTextBox",
        "label": "Admin Username",
        "toolTip": "Administrator username for the virtual machine.",
        "osPlatform": "Linux",
        "constraints": {
          "required": true
        },
        "visible": true
      },
      {
        "name": "vmCredentials",
        "type": "Microsoft.Compute.CredentialsCombo",
        "label": {
          "authenticationType": "Authentication Type",
          "password": "Password",
          "confirmPassword": "Confirm Password",
          "sshPublicKey": "SSH Public Key"
        },
        "toolTip": {
          "authenticationType": "SSH key is recommended for Linux VMs.",
          "password": "Password must be at least 12 characters.",
          "sshPublicKey": "Paste your SSH public key (starts with ssh-rsa or ssh-ed25519)."
        },
        "constraints": {
          "required": true,
          "customPasswordRegex": "^(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^a-zA-Z\\d]).{12,128}$",
          "customValidationMessage": "Password must be 12–128 characters and include uppercase, lowercase, digit, and special character."
        },
        "options": {
          "hideConfirmation": false,
          "hidePassword": false
        },
        "osPlatform": "Linux",
        "visible": true
      }
    ],
    "steps": [
      {
        "name": "vmSettings",
        "label": "VM Settings",
        "elements": [
          {
            "name": "vmSize",
            "type": "Microsoft.Compute.SizeSelector",
            "label": "Virtual Machine Size",
            "toolTip": "Select the size of the virtual machine.",
            "recommendedSizes": [
              "Standard_D2s_v3",
              "Standard_D2s_v5",
              "Standard_B2s",
              "Standard_B2ms"
            ],
            "constraints": {
              "allowedSizes": [
                "Standard_B1s",
                "Standard_B1ms",
                "Standard_B2s",
                "Standard_B2ms",
                "Standard_B4ms",
                "Standard_D2s_v3",
                "Standard_D3s_v3",
                "Standard_D4s_v3",
                "Standard_D2s_v5",
                "Standard_D3s_v5",
                "Standard_D4s_v5"
              ],
              "required": true
            },
            "osPlatform": "Linux",
            "imageReference": {
              "publisher": "RedHat",
              "offer": "RHEL",
              "sku": "9-lvm-gen2"
            },
            "count": 1,
            "visible": true
          },
          {
            "name": "securityType",
            "type": "Microsoft.Common.DropDown",
            "label": "Security Type",
            "defaultValue": "TrustedLaunch",
            "toolTip": "Trusted Launch enables Secure Boot and vTPM for enhanced VM security. Recommended for all new deployments.",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Trusted Launch (Recommended)",
                  "value": "TrustedLaunch"
                },
                {
                  "label": "Standard",
                  "value": "Standard"
                }
              ],
              "required": true
            },
            "visible": true
          },
          {
            "name": "securityInfoTrusted",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('vmSettings').securityType, 'TrustedLaunch')]",
            "options": {
              "icon": "Info",
              "text": "Trusted Launch protects your VM with Secure Boot (prevents unauthorized bootloaders and OS) and vTPM (hardware-backed security chip). Recommended for all production workloads."
            }
          },
          {
            "name": "securityInfoStandard",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('vmSettings').securityType, 'Standard')]",
            "options": {
              "icon": "Warning",
              "text": "Standard security does not include Secure Boot or vTPM. Only select this if your workload is not compatible with Trusted Launch."
            }
          }
        ]
      },
      {
        "name": "tags",
        "label": "Tags",
        "elements": [
          {
            "name": "tagsByResource",
            "type": "Microsoft.Common.TagsByResource",
            "toolTip": "Apply tags to each resource type individually. Tags help you organise and track costs across resources.",
            "resources": [
              "Microsoft.Compute/virtualMachines",
              "Microsoft.Network/virtualNetworks",
              "Microsoft.Network/networkInterfaces",
              "Microsoft.Network/networkSecurityGroups",
              "Microsoft.Network/publicIPAddresses"
            ]
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "vmName": "[basics('vmName')]",
      "adminUsername": "[basics('adminUsername')]",
      "authenticationType": "[basics('vmCredentials').authenticationType]",
      "adminPasswordOrKey": "[if(equals(basics('vmCredentials').authenticationType, 'password'), basics('vmCredentials').password, basics('vmCredentials').sshPublicKey)]",
      "vmSize": "[steps('vmSettings').vmSize]",
      "securityType": "[steps('vmSettings').securityType]",
      "tagsByResource": "[steps('tags').tagsByResource]"
    }
  }
}
