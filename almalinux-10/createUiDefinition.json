{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "metadata": {
    "description": "Create an AlmaLinux 10 virtual machine"
  },
  "parameters": {
    "basics": [
      {
        "name": "vmName",
        "type": "Microsoft.Common.TextBox",
        "label": "Virtual Machine Name",
        "toolTip": "The name of the virtual machine",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9A-Z-]{3,15}$",
          "validationMessage": "VM name must be between 3 and 15 characters, containing alphanumeric and hyphen characters only"
        },
        "visible": true
      },
      {
        "name": "adminUsername",
        "type": "Microsoft.Common.TextBox",
        "label": "Admin Username",
        "toolTip": "Administrator username for the virtual machine",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9A-Z_]{1,30}$",
          "validationMessage": "Username must be between 1 and 30 characters"
        },
        "visible": true
      },
      {
        "name": "authenticationType",
        "type": "Microsoft.Common.DropDown",
        "label": "Authentication Type",
        "defaultValue": "sshPublicKey",
        "toolTip": "Authentication method for the virtual machine",
        "constraints": {
          "allowedValues": [
            {
              "label": "SSH Public Key",
              "value": "sshPublicKey"
            },
            {
              "label": "Password",
              "value": "password"
            }
          ],
          "required": true
        },
        "visible": true
      },
      {
        "name": "adminPasswordOrKey",
        "type": "Microsoft.Common.PasswordBox",
        "label": "SSH Key or Password",
        "toolTip": "SSH public key (paste entire key starting with ssh-rsa) or password",
        "constraints": {
          "required": true,
          "regex": "^(?=.{12,})",
          "validationMessage": "Minimum 12 characters required"
        },
        "visible": true
      }
    ],
    "steps": [
      {
        "name": "vmSettings",
        "label": "VM Settings",
        "elements": [
          {
            "name": "vmSize",
            "type": "Microsoft.Compute.SizeSelector",
            "label": "Virtual Machine Size",
            "toolTip": "The size of the virtual machine",
            "recommendedSizes": [
              "Standard_B2s",
              "Standard_B2ms",
              "Standard_D2s_v3",
              "Standard_D2s_v5"
            ],
            "constraints": {
              "allowedSizes": [
                "Standard_B1s",
                "Standard_B1ms",
                "Standard_B2s",
                "Standard_B2ms",
                "Standard_B4ms",
                "Standard_D1_v2",
                "Standard_D2_v2",
                "Standard_D3_v2",
                "Standard_D4_v2",
                "Standard_D2s_v3",
                "Standard_D3s_v3",
                "Standard_D4s_v3",
                "Standard_D2s_v5",
                "Standard_D3s_v5",
                "Standard_D4s_v5"
              ],
              "required": true
            },
            "osPlatform": "Linux",
            "imageReference": {
              "publisher": "almalinux",
              "offer": "almalinux",
              "sku": "10_0"
            },
            "count": 1,
            "visible": true
          },
          {
            "name": "securityType",
            "type": "Microsoft.Common.DropDown",
            "label": "Security Type",
            "defaultValue": "TrustedLaunch",
            "toolTip": "The security type for the virtual machine",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Standard",
                  "value": "Standard"
                },
                {
                  "label": "TrustedLaunch",
                  "value": "TrustedLaunch"
                }
              ],
              "required": true
            },
            "visible": true
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "vmName": "[basics('vmName')]",
      "adminUsername": "[basics('adminUsername')]",
      "authenticationType": "[basics('authenticationType')]",
      "adminPasswordOrKey": "[basics('adminPasswordOrKey')]",
      "vmSize": "[steps('vmSettings').vmSize]",
      "almalinuxOSVersion": "AlmaLinux-10",
      "securityType": "[steps('vmSettings').securityType]"
    }
  }
}
